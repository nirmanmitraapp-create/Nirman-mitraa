# ----------------------------------------------------------------------------
# Firebase configuration
# ----------------------------------------------------------------------------
# Copy this file to ".env" and fill in the values from your Firebase project:
#   Firebase Console -> Project settings -> General -> Your apps -> SDK setup
#
# If you leave these BLANK, the app automatically runs in DEMO MODE using
# localStorage (no Firebase required). Great for previewing the UI.
# ----------------------------------------------------------------------------

VITE_FIREBASE_API_KEY=AIzaSyD73
VITE_FIREBASE_AUTH_DOMAIN=nirm
VITE_FIREBASE_PROJECT_ID=nirman
VITE_FIREBASE_STORAGE_BUCKET=nirman
VITE_FIREBASE_MESSAGING_SENDER_ID=1
VITE_FIREBASE_APP_ID=1:1489

# Optional: Cloud Messaging (push notifications) Web Push certificate key pair
VITE_FIREBASE_VAPID_KEY=

# ----------------------------------------------------------------------------
# Cloudinary — signed image uploads for gift images
# ----------------------------------------------------------------------------
# Cloud name is public; the client uses it to build the upload URL.
# The API key/secret are server-only (used by /api/cloudinary-sign to sign each
# upload). On Vercel, add CLOUDINARY_* under Settings -> Environment Variables.
VITE_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

VITE_ADMIN_EMAILS=hars
# Comma-separated list of admin emails (e.g. owner@shop.com,manager@shop.com)
# These accounts get the Admin panel. In production, prefer Firestore roles /
# custom claims instead of this list.
VITE_ADMIN_EMAILS=owner@shop.com